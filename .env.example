# Algorand MCP — environment variables
#
# All variables are optional. The MCP works out-of-the-box against
# mainnet/testnet via public Algonode endpoints with no configuration.
# Network is selected per tool call via the `network` argument; default
# is `testnet`.

# ── Algod / Indexer ──────────────────────────────────────────────────────
# API token forwarded to the Algodv2 / Indexer clients. Required only
# when pointing at a private, authenticated node. Leave blank for Algonode.
ALGORAND_TOKEN=

# ── Localnet (only when calling tools with `network: "localnet"`) ────────
# Algod base URL, e.g. http://localhost:4001
ALGORAND_LOCALNET_URL=
# Optional indexer URL. If unset, derived from ALGORAND_LOCALNET_URL by
# swapping :4001 -> :8980.
ALGORAND_LOCALNET_INDEXER_URL=

# ── Alpha Arcade ─────────────────────────────────────────────────────────
# API key for Alpha Arcade. Required to call `alpha_get_reward_markets`.
ALPHA_API_KEY=
# Optional override for the Alpha Arcade API base URL.
ALPHA_API_BASE_URL=

# ── Haystack Router ──────────────────────────────────────────────────────
# API key for Haystack Router. A working default is hardcoded in source;
# set this only if you have your own key.
HAYSTACK_API_KEY=

# ── Pagination ───────────────────────────────────────────────────────────
# Default page size for paginated tool responses. Per-call `itemsPerPage`
# arguments override this. Default: 10.
ITEMS_PER_PAGE=10
BAZAAR_BASE_URL=https://facilitator.goplausible.xyz
